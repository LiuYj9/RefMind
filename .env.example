# ===== RefMind 环境配置 =====
# 复制为 .env 后，再填写本机实际配置。

# 阿里云 DashScope API 密钥（OpenAI 兼容模式）
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY

# DashScope OpenAI 兼容接口地址
API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# 本地用户隔离 ID；多用户部署时必须由认证层注入真实且稳定的用户 ID
REFMIND_USER_ID=local_user

# 模型配置
LLM_MODEL=qwen3.7-plus
# 图片摘要和携图回答使用的全模态模型
MULTIMODAL_LLM_MODEL=qwen3.5-omni-plus-2026-03-15
# 主模型不可用时自动切换的备用模型；留空表示不启用
LLM_FALLBACK_MODEL=qwen-turbo
# 备用模型的接口地址；留空则使用 API_BASE
LLM_FALLBACK_API_BASE=
# 主模型健康检查间隔（秒），设为 0 表示每次请求都重试
LLM_HEALTH_CHECK_INTERVAL=60
# 连续失败达到该次数后暂时熔断主模型
LLM_CIRCUIT_FAILURE_THRESHOLD=3
# 兼容接口不支持 tongyi-embedding-vision-plus，请使用文本嵌入模型
# 可选 text-embedding-v4 / v3 / v2
EMBEDDING_MODEL=text-embedding-v4

# PDF 解析
# MinerU 命令；已加入 PATH 或当前虚拟环境时保持为 mineru
MINERU_BINARY_PATH=mineru
# 未安装 MinerU 时自动回退到 PyMuPDF；设为 true 可强制回退
USE_FALLBACK_PARSER=false
# MinerU 后端：pipeline、vlm-auto-engine、hybrid-auto-engine、
# vlm-http-client 或 hybrid-http-client
MINERU_BACKEND=pipeline
# MinerU 解析方式（仅 pipeline/hybrid）：auto、txt 或 ocr
MINERU_METHOD=auto
# 模型下载源：huggingface、modelscope 或 local；留空使用 MinerU 默认设置
# 国内网络环境通常使用 modelscope 更稳定
MINERU_MODEL_SOURCE=
# 进程内最大并行解析文档数（跨批次/会话共享，1~8）；单 GPU 建议 2~3
PDF_MAX_PARALLEL_DOCUMENTS=2

# 存储路径
CHROMA_PERSIST_DIR=./data/chroma_data
DATABASE_PATH=./data/refmind.db
UPLOAD_DIR=./data/uploads
PARSED_DIR=./data/parsed
# 提取出的原图存放目录，不写入向量库
DOCSTORE_DIR=./data/docstore
# 是否在入库时生成图片结构化摘要（需要配置 DASHSCOPE_API_KEY）
IMAGE_SUMMARY_ENABLED=true
# 进程内图片摘要最大并发请求数（跨文档、跨会话共享，1~8）
IMAGE_SUMMARY_MAX_WORKERS=4
# 单次回答最多发送的图片数量；超过大小限制的图片会被跳过
IMAGE_MAX_PER_ANSWER=3
IMAGE_MAX_BYTES=4194304

# 检索与记忆参数
RETRIEVAL_TOP_K=5
MEMORY_MAX_TURNS=30
MEMORY_RELEVANCE_THRESHOLD=0.3

# ===== GS 外部学术检索（仅本轮临时摘要证据，不写入 Chroma） =====
ACADEMIC_SEARCH_ENABLED=true
# 可选：auto / semantic_scholar / openalex / crossref
# auto 并行查询 Semantic Scholar 与 Crossref；OpenAlex 当前必须配置免费 API key。
ACADEMIC_SEARCH_PROVIDER=auto
# 最终送给 LLM 的论文数与检索候选数
ACADEMIC_SEARCH_TOP_K=5
ACADEMIC_SEARCH_CANDIDATE_K=15
ACADEMIC_SEARCH_TIMEOUT_SECONDS=15
ACADEMIC_SEARCH_MAX_ABSTRACT_CHARS=5000
# Semantic Scholar key 可选，但配置后限流更稳定
SEMANTIC_SCHOLAR_API_KEY=
# https://openalex.org/settings/api 获取；仅选择 openalex 时必填
OPENALEX_API_KEY=
# Crossref polite pool 联系邮箱；选择 crossref 时建议填写
CROSSREF_MAILTO=

# 跨会话长期记忆（独立 SQLite 表，不进入论文向量库）
LONG_TERM_MEMORY_ENABLED=true
LONG_TERM_MEMORY_TOP_K=6
LONG_TERM_MEMORY_SCAN_LIMIT=500
LONG_TERM_MEMORY_MAX_CANDIDATES=4
# 低于任一阈值的候选不写入
LONG_TERM_MEMORY_MIN_IMPORTANCE=0.45
LONG_TERM_MEMORY_MIN_CONFIDENCE=0.70
LONG_TERM_MEMORY_RELEVANCE_THRESHOLD=0.30
LONG_TERM_MEMORY_DUPLICATE_THRESHOLD=0.92
# 长期未使用且衰减到该权重以下时软归档
LONG_TERM_MEMORY_ARCHIVE_THRESHOLD=0.15
SEMANTIC_MEMORY_HALF_LIFE_DAYS=180
EPISODIC_MEMORY_HALF_LIFE_DAYS=45
SEMANTIC_MEMORY_MAX_INACTIVE_DAYS=730
EPISODIC_MEMORY_MAX_INACTIVE_DAYS=180
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# 表格、公式、图注等原子版面块的最大长度
LAYOUT_CHUNK_MAX_CHARS=1800
LLM_TEMPERATURE=0.1
# DashScope 兼容接口单次嵌入请求最多 10 条文本，请勿调大
EMBEDDING_BATCH_SIZE=10
# 进程内 Embedding 批次最大并发请求数（跨文档、跨会话共享，1~8）
EMBEDDING_MAX_PARALLEL_BATCHES=4
# 进程内文档中文摘要最大并发请求数（跨文档、跨会话共享，1~8）
DOCUMENT_SUMMARY_MAX_WORKERS=4

# 召回、重排与上下文压缩
# 重排前保留的候选数量
RECALL_TOP_K=20
# 是否使用重排模型；不可用时回退到嵌入相似度
RERANK_ENABLED=true
# DashScope 重排模型；未安装或调用失败时自动回退
RERANK_MODEL=gte-rerank-v2
# 重排后最终保留的分块数量
RERANK_TOP_N=5
# 是否压缩上下文，去除重复分块和无关句子
CONTEXT_COMPRESSION_ENABLED=true
# 发送给模型的上下文最大字符数
CONTEXT_MAX_CHARS=4000
# 两个分块余弦相似度高于此值时视为重复
REDUNDANCY_THRESHOLD=0.92
# 压缩上下文时过滤低于此相似度的句子
SENTENCE_RELEVANCE_THRESHOLD=0.25

# 受控的多智能体检索流程
# 规划器最多生成 3 个检索子问题，失败时回退到单问题检索
MULTI_AGENT_ENABLED=true
MULTI_AGENT_MAX_SUBQUERIES=3
MULTI_AGENT_MAX_WORKERS=3
MULTI_AGENT_RETRIEVAL_TIMEOUT=30
# 是否进行直接可回答性审查；过滤仅关键词重合或只涉及相邻主题的证据
MULTI_AGENT_EVIDENCE_REVIEW=true
# 是否基于检索证据审校答案；不直接回答原问题时拒答，审校失败时保留原答案
MULTI_AGENT_ANSWER_REVIEW=true

# 可选插件：填写逗号分隔的可导入模块名，留空表示不加载插件
# REFMIND_PLUGIN_MODULES=examples.plugins.metadata_tag
REFMIND_PLUGIN_MODULES=

# 可选 MCP 服务配置（JSON 数组）；探测前请安装 requirements-mcp.txt
# 外部 MCP 内容默认不会进入答案，除非代码显式允许
# REFMIND_MCP_SERVERS=[{"name":"local","transport":"stdio","command":"python","args":["path/to/server.py"]}]
REFMIND_MCP_SERVERS=
