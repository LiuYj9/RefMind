# ===== RefMind environment configuration =====
# Copy this file to ".env" and fill in your real values.

# Aliyun DashScope API key (OpenAI-compatible mode)
DASHSCOPE_API_KEY=your_api

# OpenAI-compatible endpoint for DashScope
API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Models
LLM_MODEL=qwen3.7-plus
# Note: the multimodal embedding model tongyi-embedding-vision-plus is NOT
# served on the OpenAI-compatible endpoint. Use a text embedding model here
# (text-embedding-v4 / v3 / v2).
EMBEDDING_MODEL=text-embedding-v4

# PDF parsing
# Command used to invoke MinerU. "mineru" works whether it is on PATH or in
# the active virtualenv's Scripts/bin directory.
MINERU_BINARY_PATH=mineru
# If MinerU is not installed, RefMind falls back to PyMuPDF automatically.
# Force the fallback parser by setting this to "true".
USE_FALLBACK_PARSER=false
# MinerU backend: pipeline (general, smaller models) | vlm-auto-engine |
# hybrid-auto-engine | vlm-http-client | hybrid-http-client
MINERU_BACKEND=pipeline
# MinerU method (pipeline/hybrid only): auto | txt | ocr
MINERU_METHOD=auto
# Model download source: huggingface | modelscope | local (blank = MinerU default)
# In mainland China, "modelscope" is usually faster/more reliable.
MINERU_MODEL_SOURCE=

# Storage locations
CHROMA_PERSIST_DIR=./data/chroma_data
DATABASE_PATH=./data/refmind.db
UPLOAD_DIR=./data/uploads
PARSED_DIR=./data/parsed

# Retrieval / memory tuning
RETRIEVAL_TOP_K=5
MEMORY_MAX_TURNS=30
MEMORY_RELEVANCE_THRESHOLD=0.3
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
LLM_TEMPERATURE=0.1
# DashScope 兼容接口单次嵌入请求最多 10 条文本，请勿调大
EMBEDDING_BATCH_SIZE=10
