# ===== RefMind environment configuration =====
# Copy this file to ".env" and fill in your real values.

# Aliyun DashScope API key (OpenAI-compatible mode)
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY

# OpenAI-compatible endpoint for DashScope
API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Models
LLM_MODEL=qwen3.7-plus
# Fallback model: auto-switch when the primary model is unreachable.
# Leave blank to disable automatic failover.
LLM_FALLBACK_MODEL=qwen-turbo
# Optional separate API endpoint for the fallback model (blank = same as API_BASE)
LLM_FALLBACK_API_BASE=
# Seconds between health-check retries on the primary model (0 = retry every call)
LLM_HEALTH_CHECK_INTERVAL=60
# Circuit breaker: consecutive failures before opening the circuit
LLM_CIRCUIT_FAILURE_THRESHOLD=3
# Note: the multimodal embedding model tongyi-embedding-vision-plus is NOT
# served on the OpenAI-compatible endpoint. Use a text embedding model here
# (text-embedding-v4 / v3 / v2).
EMBEDDING_MODEL=text-embedding-v4

# PDF parsing
# Command used to invoke MinerU. "mineru" works whether it is on PATH or in
# the active virtualenv's Scripts/bin directory.
MINERU_BINARY_PATH=mineru
# If MinerU is not installed, RefMind falls back to PyMuPDF automatically.
# Force the fallback parser by setting this to "true".
USE_FALLBACK_PARSER=false
# MinerU backend: pipeline (general, smaller models) | vlm-auto-engine |
# hybrid-auto-engine | vlm-http-client | hybrid-http-client
MINERU_BACKEND=pipeline
# MinerU method (pipeline/hybrid only): auto | txt | ocr
MINERU_METHOD=auto
# Model download source: huggingface | modelscope | local (blank = MinerU default)
# In mainland China, "modelscope" is usually faster/more reliable.
MINERU_MODEL_SOURCE=

# Storage locations
CHROMA_PERSIST_DIR=./data/chroma_data
DATABASE_PATH=./data/refmind.db
UPLOAD_DIR=./data/uploads
PARSED_DIR=./data/parsed

# Retrieval / memory tuning
RETRIEVAL_TOP_K=5
MEMORY_MAX_TURNS=30
MEMORY_RELEVANCE_THRESHOLD=0.3
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
LLM_TEMPERATURE=0.1
# DashScope 兼容接口单次嵌入请求最多 10 条文本，请勿调大
EMBEDDING_BATCH_SIZE=10

# Recall -> rerank -> context compression
# Candidate pool size before reranking
RECALL_TOP_K=20
# Rerank candidates with a rerank model; falls back to embedding similarity
RERANK_ENABLED=true
# DashScope rerank model (needs the "dashscope" package); blank/failure -> fallback
RERANK_MODEL=gte-rerank-v2
# Final number of chunks kept after reranking
RERANK_TOP_N=5
# Context compression: drop duplicate chunks and off-topic sentences
CONTEXT_COMPRESSION_ENABLED=true
# Max characters of context fed into the prompt
CONTEXT_MAX_CHARS=4000
# Two chunks with cosine similarity above this are treated as duplicates
REDUNDANCY_THRESHOLD=0.92
# Sentences below this similarity to the query are dropped during compression
SENTENCE_RELEVANCE_THRESHOLD=0.25

# Controlled multi-agent workflow
# Planner generates at most 3 retrieval-only subqueries; failures fall back to one query.
MULTI_AGENT_ENABLED=true
MULTI_AGENT_MAX_SUBQUERIES=3
MULTI_AGENT_MAX_WORKERS=3
MULTI_AGENT_RETRIEVAL_TIMEOUT=30
# Extra evidence review costs one model call and is off because reranking already filters evidence.
MULTI_AGENT_EVIDENCE_REVIEW=false
# Review the draft strictly against retrieved evidence; failure keeps the original draft.
MULTI_AGENT_ANSWER_REVIEW=true

# Optional plugins: comma-separated importable modules. Empty = no custom modules.
# REFMIND_PLUGIN_MODULES=examples.plugins.metadata_tag
REFMIND_PLUGIN_MODULES=

# Optional MCP servers as a JSON array. Install requirements-mcp.txt before probing.
# External MCP content is NOT added to answers unless code explicitly opts in.
# REFMIND_MCP_SERVERS=[{"name":"local","transport":"stdio","command":"python","args":["path/to/server.py"]}]
REFMIND_MCP_SERVERS=
